{
	"name": "skillscan",
	"version": "0.1.0",
	"description": "Security scanner for AI agent skills/plugins. Detects prompt injection, data exfiltration, excessive permissions, and supply chain attacks.",
	"type": "module",
	"bin": {
		"skillscan": "./dist/cli.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsx src/cli.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"security",
		"ai-agent",
		"scanner",
		"skills",
		"plugins",
		"prompt-injection",
		"static-analysis"
	],
	"author": "",
	"license": "Apache-2.0",
	"engines": {
		"node": ">=22"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"packageManager": "pnpm@10.32.1",
	"dependencies": {
		"chalk": "^5.6.2",
		"commander": "^14.0.3",
		"cosmiconfig": "^9.0.1",
		"gray-matter": "^4.0.3",
		"ora": "^9.3.0",
		"ts-morph": "^27.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/node": "^25.5.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	}
}
